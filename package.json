{
  "name": "kumiko-font-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm lint && tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "preview": "vite preview",
    "cf:preview": "pnpm build && npx wrangler pages dev dist",
    "cf:deploy": "pnpm build && npx wrangler pages deploy dist"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.10.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@plist/openstep.parse": "^1.1.1",
    "@tanstack/react-query": "^5.99.2",
    "fflate": "^0.8.2",
    "fonteditor-core": "2.6.3",
    "framer-motion": "12.38.0",
    "iconoir-react": "7.11.0",
    "immer": "11.1.4",
    "opentype.js": "^1.3.5",
    "paper": "0.12.18",
    "pyodide": "0.29.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.12.5",
    "zundo": "^2.3.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/opentype.js": "^1.3.9",
    "@types/paper": "0.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.5"
  }
}
